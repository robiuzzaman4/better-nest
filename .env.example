# Neon Postgres — get from neon.tech dashboard → Connection string
# keep Neon credentials secure: do not expose them to client-side code

PORT=5000

DATABASE_URL=''

# Better Auth — generate a random secret (any 32+ char string)
# Run in terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=""

# Your NestJS server URL
BETTER_AUTH_URL="http://localhost:5000"

# Google OAuth — from console.cloud.google.com
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"